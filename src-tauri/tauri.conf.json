{
  "$schema": "https://raw.githubusercontent.com/nicholasq/tauri-v2-schema/main/tauri-v2.schema.json",
  "productName": "CodeWhale Desktop",
  "version": "0.1.0",
  "identifier": "net.codewhale.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CodeWhale Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "minimumSystemVersion": "12.4"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        { "name": "codewhale", "cmd": "codewhale", "args": true },
        { "name": "node", "cmd": "node", "args": true }
      ]
    }
  }
}
